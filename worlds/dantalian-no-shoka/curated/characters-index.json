    {"id":"hugh-anthony-disward","name":"修伊·安索尼·迪斯瓦特","aliases":["修·安东尼·迪斯瓦德","修伊","休伊"],"visibility":"public","summary":"退役空军飞行员，继承祖父宅邸与黄金钥匙后成为黑之读姬的钥匙守护者。冷静、温和、行动力强，是保存与封印幻书路线的核心人物。","roles":["主角","钥匙守护者","前飞行员","调查者"],"factions":["dantalian-pair"],"locations":["disward-estate","capital"],"powerSystems":["dantalian-library","phantom-books"],"abilities":["开启丹特丽安的书架","军用格斗与枪械","飞行经验","调查与临场判断"],"items":["黄金/红宝石钥匙"],"relationships":["dalian:契约读姬/同伴","camilla-cairns:青梅竹马","hal-kamhout:理念对立但可临时合作","flamberge:焚书官搭档的读姬"],"importance":"critical","evidenceLevel":"A","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"OC 不应默认取代其钥匙守护者身份。"},
    {"id":"dalian","name":"妲丽安","aliases":["丹特丽安","达利安","但他林","黑之读姬"],"visibility":"public","summary":"外表十二三岁的黑衣少女，体内封印九十万零六百六十六册幻书的‘丹特丽安的书架’。毒舌、怕生、傲慢，极爱炸面包和甜食，内心有温柔面。","roles":["主角","黑之读姬","壶中之天","书架守护者"],"factions":["dantalian-pair"],"locations":["disward-estate","phantom-library"],"powerSystems":["dantalian-library","phantom-books"],"abilities":["封印幻书","回应契约问答","提供对应幻书","壶中天空间转移书籍"],"items":["胸前锁","书架内幻书"],"relationships":["hugh-anthony-disward:钥匙守护者/同伴","camilla-cairns:友人","raziel:同类对立","flamberge:读姬同类"],"importance":"critical","evidenceLevel":"A","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"仪式回应常为‘否，吾乃天——壶中之天’。"},
    {"id":"hal-kamhout","name":"哈尔·卡姆赫德","aliases":["哈尔·卡姆霍德","哈尔","教授（部分条目称谓）"],"visibility":"public","summary":"焚书官，灰发或白衣美男子形象，持银色长杖‘灾厄之枝’，将幻书作为燃料烧毁。其理念是幻书必须被彻底毁灭。","roles":["焚书官","对立者","幻书猎杀者"],"factions":["burning-officers"],"locations":["capital","razkeso-castle","dark-continent"],"powerSystems":["burning-officer-technique","phantom-books"],"abilities":["幻书装填爆发","巴流术/格斗","追踪幻书","焚毁概念魔力"],"items":["灾厄之枝","摩托车"],"relationships":["flamberge:搭档读姬","hugh-anthony-disward:理念对立/临时合作","dalian:保存派对立","yuna:被诱导利用"],"importance":"critical","evidenceLevel":"A","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"与教授称谓存在条目混用，curated 中按焚书官哈尔处理。"},
    {"id":"flamberge","name":"芙兰蓓尔","aliases":["芙兰","芙兰卑尔奇","银之读姬","毁灭读姬","毁坏的书姬"],"visibility":"public","summary":"哈尔的搭档，身穿白色拘束衣，身体/拉链中藏有通往毁灭的门扉。她配合焚书官装填幻书并释放毁灭性业火。","roles":["银之读姬","毁灭读姬","焚书官搭档"],"factions":["burning-officers"],"locations":["capital","razkeso-castle","dark-continent"],"powerSystems":["burning-officer-technique","phantom-books"],"abilities":["开启堕落之天/毁灭之门","供哈尔装填幻书"],"items":["拘束衣","锁头","拉链门扉"],"relationships":["hal-kamhout:钥匙/搭档","dalian:读姬同类"],"importance":"high","evidenceLevel":"A","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"仪式回应常为‘非也，吾乃天——堕落之天也’。"},
    {"id":"raziel","name":"拉结尔","aliases":["拉洁爱尔","赤之读姬"],"visibility":"private","summary":"赤之读姬，左眼为书架入口或覆有锁头眼罩，性格残酷傲慢。她与教授观察幻稿孵化，认为幻书诞生需要疯狂。","roles":["赤之读姬","研究者搭档","对立读姬"],"factions":["professor-raziel"],"locations":["battlefront-airbase","newdwalt"],"powerSystems":["raziel-library","phantom-books"],"abilities":["开启赤之书架","观察幻稿孵化","精神压迫"],"items":["左眼书架/锁头眼罩"],"relationships":["professor:搭档","dalian:同类对立","hugh-anthony-disward:敌对观察对象"],"importance":"critical","evidenceLevel":"A","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"默认不向普通 PC 直接剧透其全部目的。"},
    {"id":"professor","name":"教授","aliases":["幻书研究者","中性美男子"],"visibility":"private","summary":"幕后研究者，追求幻书产生过程和新幻书/幻稿实验，曾利用无面亡灵、连接之书、核分裂/集体意识等危险课题。","roles":["反派研究者","幻稿观察者"],"factions":["professor-raziel"],"locations":["battlefront-airbase","newdwalt"],"powerSystems":["raziel-library","phantom-books"],"abilities":["复活/利用死者","设计大规模实验","操纵幻稿条件"],"items":[],"relationships":["raziel:搭档","hugh-anthony-disward:敌对","dalian:敌对"],"importance":"critical","evidenceLevel":"B","sourceRefs":["src-dantalian-no-shoka-001"],"notes":"部分条目把哈尔也称为教授；此处作为研究幻稿的一方单独列出。"},
