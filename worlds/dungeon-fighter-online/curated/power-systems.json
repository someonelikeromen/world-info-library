    {
      "id": "transfer-and-dimensionality",
      "name": "转移 / 异次元 / 裂缝",
      "category": "world-event-mechanism",
      "visibility": "private",
      "summary": "转移将使徒或区域性灾厄移动到阿拉德、天界或其他地点，并与异次元裂缝、次元风暴、寂静城、瓦哈伊特等后期路线相连。",
      "principle": "源中多次将重大灾厄描述为赫尔德转移或空间通道破坏/开启的结果；作为RP机制时应视为高危剧情装置而非常规传送技能。",
      "commonResources": [
        "赫尔德的转移手段",
        "寂静城等通道",
        "异次元裂缝",
        "次元航船瓦哈伊特"
      ],
      "commonAbilities": [
        "跨地点灾厄投放",
        "通道封锁/开启",
        "时间或扭曲次元探索"
      ],
      "limitations": [
        "转移后果常不可控，会造成瘟疫、生态变异、精神控制或地区战争。",
        "低阶角色通常只能调查、封印或借助组织设施应对，不能自由复刻。"
      ],
      "evidenceLevel": "B"
    },
