      "id": "kekkai-jutsu",
      "name": "结界术",
      "rules": [
        "以方围、定础、结、灭等步骤形成方形结界并封灭目标。",
        "精度、速度、领域感知和术者心象决定战斗效率。",
        "正统继承者可与乌森之地发生特殊共鸣。"
      ]
    },
    {
      "id": "karasumori",
      "name": "乌森之地",
      "rules": [
        "乌森会吸引并强化妖怪，导致学校夜间成为高危区域。",
        "乌森力量与历史、间时守和宙心丸线有关，适合 GM-only 渐进公开。"
      ]
